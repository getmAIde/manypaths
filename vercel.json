{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "helpers": false,
        "includeFiles": [
          "index.html",
          "research.html",
          "styles.css",
          "app.js",
          "i18n.js",
          "research-ui.js",
          "og-default.png",
          "research-engine.js",
          "og-generator.js",
          "costTracker.js",
          "robots.txt",
          "logo/**",
          "node_modules/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
